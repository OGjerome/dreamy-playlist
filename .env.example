DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/omnigroove_db?schema=public"

# Spotify OAuth — https://developer.spotify.com/dashboard
# Redirect URI: http://localhost:3000/api/auth/callback/spotify
AUTH_SPOTIFY_ID=your_spotify_client_id
AUTH_SPOTIFY_SECRET=your_spotify_client_secret

# NextAuth
AUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000